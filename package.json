{
  "name": "call-hierarchy-plus",
  "displayName": "Call Hierarchy Plus (CHP)",
  "description": "Enhanced call hierarchy for C/C++ projects. Bridges the gap between direct function calls and indirect pointer assignments/callbacks.",
  "version": "1.0.0",
  "publisher": "pyshen",
  "repository": "https://github.com/pyshen-watson/Call-Hierarchy-Plus",
  "icon": "media/sidebar-icon.png",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onCommand:call-hierarchy-plus.run",
    "onView:chpView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "call-hierarchy-plus.run",
        "title": "Show Call Hierarchy (Enhanced)",
        "category": "Call Hierarchy Plus"
      },
      {
        "command": "call-hierarchy-plus.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "call-hierarchy-plus.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      }
    ],
    "keybindings": [
      {
          "command": "call-hierarchy-plus.run",
          "key": "ctrl+shift+c",
          "mac": "cmd+shift+c",
          "when": "editorTextFocus && (editorLangId == c || editorLangId == cpp)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "call-hierarchy-plus.run",
          "group": "navigation@1",
          "when": "editorLangId == c || editorLangId == cpp"
        }
      ],
      "view/title": [
        {
          "command": "call-hierarchy-plus.refresh",
          "when": "view == chpView",
          "group": "navigation@1"
        },
        {
          "command": "call-hierarchy-plus.collapseAll",
          "when": "view == chpView",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chp-explorer",
          "title": "Call Hierarchy Plus",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "chp-explorer": [
        {
          "id": "chpView",
          "name": "Hierarchy Results",
          "collapseAll": true
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.106.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}